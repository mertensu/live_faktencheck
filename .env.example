# ===========================================
# Fact-Check Application Configuration
# ===========================================
# Copy this file to .env and fill in your API keys

# API Keys (required)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key
GEMINI_API_KEY=your_google_gemini_api_key
# Alternative: GOOGLE_API_KEY also works
TAVILY_API_KEY=your_tavily_api_key

# GitHub (optional - for auto-commit/push of fact-check JSON files)
GITHUB_TOKEN=your_github_token

# ===========================================
# Model Configuration
# ===========================================
# Change these to experiment with different models
# See: https://ai.google.dev/gemini-api/docs/models

GEMINI_MODEL_CLAIM_EXTRACTION=gemini-2.5-pro
GEMINI_MODEL_FACT_CHECKER=gemini-2.5-pro
GEMINI_MODEL_SELF_CRITIQUE=gemini-2.5-flash

# Self-critique step after fact-checking (set to "false" to disable)
SELF_CRITIQUE_ENABLED=true

# ======================
# Search configuration
# ======================

TAVILY_SEARCH_DEPTH=basic   # or "advanced"
TAVILY_MAX_RESULTS=5

# ===========================================
# Processing Configuration
# ===========================================

# Parallel fact-checking (default: false = sequential processing)
# Set to "true" to process multiple claims concurrently
FACT_CHECK_PARALLEL=true

# Maximum concurrent fact-checks within a single batch (when parallel mode is enabled)
FACT_CHECK_MAX_WORKERS=4

# Maximum concurrent approval batches processed simultaneously
FACT_CHECK_MAX_CONCURRENCY=2

# ===========================================
# Server Configuration
# ===========================================

# Flask server port
FLASK_PORT=5000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Language for LLM schema descriptions (selects prompts/lang_<LANG>.toml)
LANG=de

# ===========================================
# Frontend Configuration (Vite)
# ===========================================

# Backend URL for production builds
VITE_BACKEND_URL=https://api.live-faktencheck.de

# N8N webhook URL for verified claims (optional)
# VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/verified-claims
